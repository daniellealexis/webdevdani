$highlight = #9F6B78
$borderColor = #EEEEEE

///Featured Post on Homepage
.featured-post-wrap {
    min-height: 512px;
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    color: #fff;
    padding: 3em;
}

.featured-post-wrap h2{
    color #fff;
}

a.featured-link-wrap:hover{
    text-decoration: none;
}